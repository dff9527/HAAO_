+
+
+def _truncate_visible(text: str, width: int) -> str:
+    visible = 0
+    index = 0
+    cut = 0
+    while index < len(text):
+        match = _ansi_re.match(text, index)
+        if match is not None:
+            index = match.end()
+            continue
+        visible += 1
+        index += 1
+        cut = index
+        if visible >= width:
+            break
+    return text[:cut]
+
+
+def _split_visible(text: str, width: int) -> t.Tuple[str, str]:
+    head = _truncate_visible(text, width)
+    tail = text[len(head):]
+    if tail and term_len(tail) == 0:
+        head += tail
+        tail = ""
+    return head, tail
+
 
