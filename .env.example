CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Required BEFORE adding any cloud model API key in Settings → Cloud models.
# It encrypts those keys at rest. Generate a strong value, e.g.:
#   openssl rand -base64 32
# After setting/changing this, recreate the backend so it is picked up (see README).
HAAO_SECRET_KEY=
# Optional. When set, /api/* routes and ticket log websockets require Bearer auth.
HAAO_API_TOKEN=
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LOCAL_MAX_OUTPUT_TOKENS=4096
LOCAL_PATCH_MODE_THRESHOLD_TOKENS=2048
# Docker containers reach LM Studio through the host gateway, not localhost.
DOCKER_LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
DATABASE_URL=sqlite:///./haao.sqlite3
